# ── AOリサーチ — 環境変数サンプル ───────────────────────────
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# LLM プロバイダ（少なくとも1つ必須。複数あると自動フォールバック・比較が機能）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Google OAuth2（Google Cloud Console で取得）
# リダイレクト URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT シークレット（openssl rand -hex 32 で生成）
JWT_SECRET_KEY=

# Stripe（Stripe Dashboard で取得）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STUDENT=price_xxx
STRIPE_PRICE_TUTOR=price_xxx
STRIPE_PRICE_SCHOOL=price_xxx

# メール送信（Resend — https://resend.com）
RESEND_API_KEY=
FROM_EMAIL=AOリサーチ <noreply@ao.helphero.jp>

# エラー監視（Sentry — https://sentry.io）
SENTRY_DSN=

# データ保存先（本番: /data — Railway Volume）
DATA_DIR=

# アプリ設定
BASE_URL=http://localhost:8000
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8000
